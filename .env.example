GOOGLE_API_KEY=your_gemini_api_key_here
MODEL_ID=gemini-2.5-flash-lite

# --- agents/rag only (Vertex AI RAG Engine) ---
# Uncomment and fill these when you want to run the RAG agent. Note: setting
# GOOGLE_GENAI_USE_VERTEXAI=True routes ALL agents in the picker through Vertex
# (it is a process-wide switch), so the other agents then need this project +
# billing instead of GOOGLE_API_KEY.
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# RAG_CORPUS=  # filled in automatically by prepare_corpus_and_data.py
#
# Auth (no gcloud):
#   - On Google Cloud (Cloud Run/GKE): attach a service account and leave the
#     line below UNSET — ADC reads short-lived creds from the metadata server.
#   - Off Google Cloud / to emulate prod locally: point this at a service-account
#     JSON key OR a Workload Identity Federation credential config. ADC picks it
#     up automatically. Store it under secrets/ (gitignored) or outside the repo.
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/secrets/rag-agent-sa-key.json
#
# Or keep the key inline instead of a file. Use base64 to avoid quoting/newline
# pain (recommended):  base64 -w0 secrets/rag-agent-sa-key.json
# GOOGLE_SERVICE_ACCOUNT_JSON=ewogICJ0eXBlIjogInNlcnZpY2Vf...
# Raw JSON also works but MUST be wrapped in single quotes (one line):
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...", ...}'
